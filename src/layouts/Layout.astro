---
import '../styles/global.css';
import { Font, type CssVariable } from 'astro:assets';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Astro + Tailwind + Sanity + Mux + GSAP + Cloudflare' } = Astro.props;
const FONTS: CssVariable[] = ['--font-helvetica'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {FONTS.map((font) => <Font cssVariable={font} preload />)}
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-black var(--font-helvetica)">
    <div
      class="fixed top-0 left-0 right-0 h-fit flex flex-row justify-between text-md px-2 uppercase z-50 text-white pt-2 bg-white tracking-[-1%]"
    >
      <h3 class="mix-blend-exclusion">Justin Abernethy</h3>
      <h3 class="mix-blend-exclusion">+ INFO</h3>
    </div>
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  const lenis = new Lenis({
    autoRaf: true,
  });

  // Listen for the scroll event and log the event data
  lenis.on('scroll', (e) => {
    console.log(e);
  });
</script>
